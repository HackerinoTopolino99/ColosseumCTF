config:
  core.https_address: {{ server_1 }}:8443
networks:
- name: incusbr0
  type: bridge
  config:
    ipv4.address: 172.16.0.1/23
    ipv4.dhcp: yes
    ipv4.nat: yes
    ipv4.dhcp.range: 172.16.0.3-172.16.1.254
storage_pools:
- name: local
  driver: dir
profiles:
- name: default
  devices:
    root:
      path: /
      pool: local
      type: disk
    eth0:
      name: eth0
      nictype: bridged
      parent: incusbr0
      type: nic
cluster:
  server_name: {{ server_name }}
  enabled: true
